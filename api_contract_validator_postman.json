    {
      "name": "06 — Seed Reproducibility",
      "item": [
        {
          "name": "Reset with seed=42",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Passing a seed gives you a deterministic episode.",
                  "// Same seed = same violations every time.",
                  "// This is important for training: agents can replay the same episode.",
                  "// Run this twice and compare the payload — it should be identical."
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Reset OK', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "// Save payload to environment variable for comparison",
                  "pm.environment.set('seed42_payload', JSON.stringify(body.observation.payload));",
                  "console.log('Seed 42 payload:', JSON.stringify(body.observation.payload, null, 2));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"task_name\": \"find_type_mismatches\", \"seed\": 42}"
            },
            "url": "{{base_url}}/reset"
          }
        },
        {
          "name": "Reset with seed=42 again (must match)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Reset OK', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "var saved = pm.environment.get('seed42_payload');",
                  "pm.test('Same seed produces identical payload', function () {",
                  "    pm.expect(JSON.stringify(body.observation.payload)).to.eql(saved);",
                  "});",
                  "console.log('Payloads match:', JSON.stringify(body.observation.payload) === saved);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"task_name\": \"find_type_mismatches\", \"seed\": 42}"
            },
            "url": "{{base_url}}/reset"
          }
        },
        {
          "name": "Reset with seed=99 (must differ)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Reset OK', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "var saved = pm.environment.get('seed42_payload');",
                  "pm.test('Different seed produces different payload', function () {",
                  "    pm.expect(JSON.stringify(body.observation.payload)).to.not.eql(saved);",
                  "});",
                  "console.log('Payloads differ (expected):', JSON.stringify(body.observation.payload) !== saved);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"task_name\": \"find_type_mismatches\", \"seed\": 99}"
            },
            "url": "{{base_url}}/reset"
          }
        }
      ]
    }
